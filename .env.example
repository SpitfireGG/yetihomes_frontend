# ─── Required ───────────────────────────────────────────────────────────────
# URL of the NestJS backend API (with /api suffix)
NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api

# ─── Revalidation ───────────────────────────────────────────────────────────
# Shared secret for the /api/revalidate endpoint.
# Must match the value the backend sends when it POSTs after CUD operations.
# Generate a strong random secret: openssl rand -hex 32
REVALIDATION_SECRET=change-this-to-a-random-secret

# ─── Optional ───────────────────────────────────────────────────────────────
# Resend API key for transactional emails (contact form, etc.)
# Get one at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx

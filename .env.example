# Production — set to your live API domain
NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api

# Resend API key for sending emails (optional, get from resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Secret for the /api/revalidate endpoint (must match value used by backend)
REVALIDATION_SECRET=change-this-to-a-random-secret
